generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Patient {
  id            String   @id @default(cuid())
  nom           String
  prenom        String
  dateNaissance DateTime
  sexe          String
  telephone     String?
  adresse       String?
  region        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}